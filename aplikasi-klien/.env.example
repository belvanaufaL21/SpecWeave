# Supabase Configuration (REQUIRED)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# API Configuration
VITE_API_URL=http://localhost:5003/api

# Logging Configuration (OPTIONAL)
# Set to 'false' to disable startup messages
VITE_ENABLE_STARTUP_MESSAGE=true
# Set log level: 'debug', 'info', 'warn', 'error', 'none'
VITE_LOG_LEVEL=info

# Instructions:
# 1. Create a Supabase project at https://supabase.com
# 2. Copy your project URL and anon key from Settings > API
# 3. Replace the values above with your actual Supabase credentials
# 4. Make sure your Supabase project has the required tables (see SUPABASE_SETUP.md)