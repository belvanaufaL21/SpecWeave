    "test:run": "vitest --run",
    "clean": "vite build --force",
    "clean-logs": "node clean-logs.js",
    "clean-logs:dry-run": "node clean-logs.js --dry-run"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@monaco-editor/react": "^4.7.0",
