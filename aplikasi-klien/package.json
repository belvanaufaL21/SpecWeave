{
  "name": "specweave-client",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "SpecWeave Client Application",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "npx serve -s dist -l 3000",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
