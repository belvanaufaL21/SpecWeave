# ============================================================================
# SpecWeave Docker Deployment - Environment Variables Template
# ============================================================================
# 
# This file contains all environment variables required for Docker deployment.
# Copy this file to .env and fill in your actual values.
#
# SECURITY WARNING: Never commit .env file with real credentials to version control!
# ============================================================================

# ============================================================================
# FRONTEND CONFIGURATION (Build-time variables for React/Vite)
# ============================================================================
# These variables are embedded into the frontend build at build time.
# Changes require rebuilding the frontend Docker image.
# 
# IMPORTANT: After changing these values, you must rebuild:
#   docker-compose -f docker-compose.yml -f docker-compose.dev.yml build frontend

# Supabase Configuration (REQUIRED)
# Get these values from your Supabase project dashboard: Settings > API
# 1. Go to https://app.supabase.com/project/<your-project>/settings/api
# 2. Copy "Project URL" to VITE_SUPABASE_URL
# 3. Copy "anon public" key to VITE_SUPABASE_ANON_KEY
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# API Base URL (REQUIRED)
# This tells the frontend where to send API requests
# 
# For development mode:
#   Use: http://localhost:5003 (direct backend connection)
# 
# For production mode with Nginx reverse proxy:
#   Use: /api (relative path, Nginx will route to backend)
#   Or: https://yourdomain.com/api (absolute URL with your domain)
VITE_API_BASE_URL=http://localhost:5003


# ============================================================================
# BACKEND CONFIGURATION (Runtime variables for Node.js/Express)
# ============================================================================
# These variables are loaded at container startup and can be changed without rebuild.
# Simply restart the container after changing: docker-compose restart backend

# Server Configuration
# PORT: The port where the backend API server will listen
# Default: 5003 (must match the port exposed in docker-compose.yml)
PORT=5003

# NODE_ENV: Application environment mode
# Options: development | production | test
# - development: Enables debug logging, hot-reload, detailed error messages
# - production: Optimized performance, minimal logging, error handling
# - test: Used for running automated tests
NODE_ENV=development

# Client URL for CORS (REQUIRED)
# Comma-separated list of allowed origins for Cross-Origin Resource Sharing
# This prevents unauthorized domains from accessing your API
# 
# Examples:
#   Development: http://localhost:3000
#   Production: https://yourdomain.com,https://www.yourdomain.com
#   Multiple: http://localhost:3000,https://staging.yourdomain.com,https://yourdomain.com
CLIENT_URL=http://localhost:3000

# Supabase Configuration (REQUIRED)
# Get these from: https://app.supabase.com/project/<your-project>/settings/api
# 
# SECURITY WARNING:
# - ANON_KEY: Safe to expose in frontend (limited permissions)
# - SERVICE_ROLE_KEY: NEVER expose in frontend! Has admin permissions!
#   Only use SERVICE_ROLE_KEY in backend for privileged operations
# 
# 1. Copy "Project URL" to SUPABASE_URL
# 2. Copy "anon public" key to SUPABASE_ANON_KEY
# 3. Copy "service_role secret" key to SUPABASE_SERVICE_ROLE_KEY
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Database Configuration (Optional - if using direct PostgreSQL connection)
# Only needed if you want to bypass Supabase client and connect directly to PostgreSQL
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
# Example: postgresql://postgres:mypassword@db.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:password@host:5432/database


# ============================================================================
# EXTERNAL API INTEGRATIONS
# ============================================================================

# Groq AI API Key (REQUIRED for AI-powered scenario generation)
# Groq provides fast LLM inference for generating Gherkin scenarios
# 
# How to get your API key:
# 1. Sign up at https://console.groq.com
# 2. Navigate to API Keys section
# 3. Click "Create API Key"
# 4. Copy the key and paste it here
# 
# SECURITY: Keep this key secret! Never commit to version control!
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini API Key (REQUIRED for multi-provider LLM support)
# Gemini provides advanced AI models for generating Gherkin scenarios
# 
# How to get your API key:
# 1. Go to https://aistudio.google.com/app/apikey
# 2. Click "Create API Key" or "Get API Key"
# 3. Copy the key and paste it here
# 
# Used for:
# - Gemini 2.5 Flash (standard tier, 10 requests per user)
# - Gemini 2.5 Pro (premium tier, 1 request per user)
# 
# SECURITY: Keep this key secret! Never commit to version control!
GEMINI_API_KEY=your_gemini_api_key_here

# OpenRouter API Key (REQUIRED for multi-model LLM support)
# OpenRouter provides access to 300+ models through a single API
# 
# How to get your API key:
# 1. Sign up at https://openrouter.ai/
# 2. Go to https://openrouter.ai/keys
# 3. Click "Create Key"
# 4. Copy the key and paste it here
# 
# Benefits:
# - No rate limits (unlike direct Gemini API: 2 req/min for Pro)
# - Access to multiple providers: Anthropic, OpenAI, Google, Meta, etc.
# - Competitive pricing, free models available
# - OpenAI-compatible API (easy integration)
# 
# Models available in SpecWeave:
# - Llama 3.3 70B (FREE) - Meta
# - Gemini 2.5 Flash ($0.75/1M) - Google
# - GPT-4.1 Mini ($0.38/1M) - OpenAI
# - Claude 4.5 Haiku ($3/1M) - Anthropic
# 
# SECURITY: Keep this key secret! Never commit to version control!
OPENROUTER_API_KEY=your_openrouter_api_key_here

# App URL (for OpenRouter attribution)
# Used by OpenRouter to track API usage and provide analytics
# Set to your production URL or localhost for development
APP_URL=http://localhost:3000

# JIRA Integration (Optional - for JIRA export features)
# This encryption key is used to securely store JIRA credentials in the database
# Users can connect their JIRA accounts to export scenarios directly to JIRA
# 
# SECURITY CRITICAL:
# - This key encrypts sensitive JIRA credentials (API tokens, passwords)
# - MUST be changed in production to a strong random key
# - If this key is lost, all stored JIRA credentials become unrecoverable
# - If this key is compromised, all JIRA credentials are at risk
# 
# Generate a strong key:
#   Linux/Mac: openssl rand -base64 32
#   Windows PowerShell: [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Minimum 0 -Maximum 256 }))
# 
# Default is provided for development only - CHANGE IN PRODUCTION!
JIRA_ENCRYPTION_KEY=change-this-to-a-strong-random-key-in-production


# ============================================================================
# PYTHON SERVICES CONFIGURATION
# ============================================================================
# SpecWeave uses Python for advanced NLP evaluation (METEOR, Sentence-BERT)

# Python Interpreter Path
# Default: python (uses system Python)
# Docker: Automatically set to python3 in container
# Only change if you have a custom Python installation path
PYTHON_PATH=python

# METEOR Evaluation Configuration
# METEOR is a metric for evaluating machine translation quality
# Used to assess the quality of generated Gherkin scenarios
# 
# METEOR_SCRIPT_PATH: Path to the Python METEOR evaluator script
# METEOR_QUALITY_THRESHOLD: Minimum score (0.0-1.0) for acceptable quality
#   - 0.7 = Good quality (recommended)
#   - 0.5 = Acceptable quality
#   - 0.9 = Excellent quality (strict)
METEOR_SCRIPT_PATH=./scripts/meteor_evaluator.py
METEOR_QUALITY_THRESHOLD=0.7

# Python ML Service Configuration
# Controls how Python services are executed and managed
# 
# PYTHON_MAX_CONCURRENT: Maximum number of concurrent Python processes
#   - Higher = More parallel processing, more memory usage
#   - Lower = Less memory, slower for batch operations
#   - Recommended: 5 for 4GB RAM, 10 for 8GB RAM
PYTHON_MAX_CONCURRENT=5

# PYTHON_TIMEOUT_MS: Maximum time (milliseconds) to wait for Python response
#   - Increase if you get timeout errors
#   - Decrease for faster failure detection
PYTHON_TIMEOUT_MS=30000

# PYTHON_RETRY_ATTEMPTS: Number of retries on Python service failure
#   - Helps handle transient errors
#   - 0 = No retries, fail immediately
PYTHON_RETRY_ATTEMPTS=2

# PYTHON_RETRY_DELAY_MS: Delay (milliseconds) between retry attempts
PYTHON_RETRY_DELAY_MS=1000

# PYTHON_CACHE_ENABLED: Enable caching of Python evaluation results
#   - true = Cache results for identical inputs (faster, uses memory)
#   - false = Always recompute (slower, no memory overhead)
PYTHON_CACHE_ENABLED=true

# PYTHON_CACHE_TTL: Cache time-to-live in seconds
#   - How long to keep cached results before recomputing
PYTHON_CACHE_TTL=3600


# ============================================================================
# REDIS CACHE (Optional - falls back to in-memory cache if not available)
# ============================================================================
# Redis provides persistent caching across container restarts
# If not configured, the application will use in-memory cache (lost on restart)
# 
# To use Redis:
# 1. Add Redis service to docker-compose.yml
# 2. Set REDIS_URL to redis://redis:6379 (for Docker network)
# 3. Or use external Redis service (e.g., Redis Cloud, AWS ElastiCache)
# 
# REDIS_URL: Connection string for Redis server
#   Format: redis://[username:password@]host:port[/database]
#   Examples:
#     - Local: redis://localhost:6379
#     - Docker: redis://redis:6379
#     - Auth: redis://:password@localhost:6379
#     - Cloud: redis://username:password@redis-cloud.com:12345
REDIS_URL=redis://localhost:6379

# REDIS_MAX_RETRIES: Number of connection retry attempts
#   - Helps handle temporary network issues
REDIS_MAX_RETRIES=3

# REDIS_RETRY_DELAY: Delay (milliseconds) between connection retries
REDIS_RETRY_DELAY=1000


# ============================================================================
# LOGGING AND MONITORING
# ============================================================================
# Configure application logging behavior and verbosity

# Log Level: Controls which log messages are output
# Options: DEBUG | INFO | WARN | ERROR
# - DEBUG: All messages (very verbose, use for troubleshooting)
# - INFO: Informational messages and above (recommended for development)
# - WARN: Warnings and errors only (recommended for production)
# - ERROR: Only error messages (minimal logging)
LOG_LEVEL=INFO

# Enable/disable console logs
# true: Log to stdout/stderr (visible in docker-compose logs)
# false: Disable console logging (use file logging only)
# Recommended: true for Docker (Docker captures stdout/stderr)
ENABLE_CONSOLE_LOGS=true

# Health check verbosity
# true: Log every health check request (noisy)
# false: Only log health check failures (recommended)
# Note: Health checks run every 30 seconds, so verbose mode creates many logs
HEALTH_CHECK_VERBOSE=false

# Health check log level override
# Set a different log level specifically for health check endpoint
# Useful to reduce noise from frequent health checks
# Options: DEBUG | INFO | WARN | ERROR
HEALTH_CHECK_LOG_LEVEL=error

# Clean logs mode (reduces noise in production)
# true: Minimal logging, hide verbose debug info
# false: Full logging with all details
# Recommended: false for development, true for production
CLEAN_LOGS=false

# Skip optional database tables (useful if tables don't exist yet)
# Set to true if you haven't created these optional tables in Supabase
# The application will continue to work, just without these features
# 
# SKIP_ERROR_LOGS_TABLE: Skip logging errors to database
# SKIP_PERFORMANCE_LOGS_TABLE: Skip logging performance metrics to database
# SKIP_MONITORING_ALERTS_TABLE: Skip creating monitoring alerts in database
SKIP_ERROR_LOGS_TABLE=false
SKIP_PERFORMANCE_LOGS_TABLE=false
SKIP_MONITORING_ALERTS_TABLE=false


# ============================================================================
# PERFORMANCE AND MONITORING
# ============================================================================
# Configure performance monitoring and alerting thresholds

# Node.js Performance Optimization (Optional - has sensible defaults)
# NODE_OPTIONS: Advanced Node.js runtime flags for memory and performance tuning
# 
# Default values (automatically set in docker-compose.yml):
#   - Base/Development: --max-old-space-size=2048 (2GB heap)
#   - Production: --max-old-space-size=3072 --max-semi-space-size=64 --optimize-for-size (3GB heap)
# 
# Only override if you need custom memory settings:
#   - Increase if you get "JavaScript heap out of memory" errors
#   - Decrease if you have limited RAM available
# 
# Common flags:
#   --max-old-space-size=<MB>: Maximum heap size in megabytes
#   --max-semi-space-size=<MB>: Young generation size (affects GC frequency)
#   --optimize-for-size: Reduce memory footprint (production)
# 
# Examples:
#   Low memory (1GB): NODE_OPTIONS=--max-old-space-size=768
#   High memory (8GB): NODE_OPTIONS=--max-old-space-size=6144
#   Custom: NODE_OPTIONS=--max-old-space-size=4096 --max-semi-space-size=128
# 
# Leave commented to use defaults from docker-compose.yml
# NODE_OPTIONS=--max-old-space-size=2048

# Performance alert threshold in milliseconds
# If an API request takes longer than this, an alert will be logged
# Helps identify slow endpoints that need optimization
# 
# Recommended values:
#   - Development: 2000ms (2 seconds)
#   - Production: 1000ms (1 second) for better user experience
PERFORMANCE_ALERT_THRESHOLD_MS=2000

# Monitoring webhook URL (Optional - for external alerting)
# Send alerts to external monitoring services (e.g., Slack, PagerDuty, Discord)
# 
# Examples:
#   - Slack: https://hooks.slack.com/services/YOUR/WEBHOOK/URL
#   - Discord: https://discord.com/api/webhooks/YOUR/WEBHOOK
#   - Custom: https://your-monitoring-service.com/alerts
# 
# Leave empty to disable webhook alerts
# MONITORING_WEBHOOK_URL=https://your-webhook-url.com/alerts

# Alert email (Optional - for email notifications)
# Send critical alerts to this email address
# Requires email service configuration (not included by default)
# ALERT_EMAIL=alerts@yourdomain.com


# ============================================================================
# DOCKER-SPECIFIC CONFIGURATION
# ============================================================================
# These variables are typically set in docker-compose.yml but can be overridden here.
# Most users don't need to change these values.

# Container restart policy
# Options: no | always | on-failure | unless-stopped
# - no: Never restart automatically
# - always: Always restart (even after manual stop)
# - on-failure: Only restart if container exits with error
# - unless-stopped: Always restart unless manually stopped (recommended)
# RESTART_POLICY=unless-stopped

# Health check interval in seconds
# How often Docker checks if the container is healthy
# Lower = Faster failure detection, more overhead
# Higher = Less overhead, slower failure detection
# HEALTH_CHECK_INTERVAL=30

# Health check timeout in seconds
# Maximum time to wait for health check response
# If exceeded, the check is considered failed
# HEALTH_CHECK_TIMEOUT=10

# Health check retries before marking unhealthy
# Number of consecutive failures before container is marked unhealthy
# Helps avoid false positives from temporary issues
# HEALTH_CHECK_RETRIES=3

# Health check start period in seconds
# Grace period before health checks start (allows app to initialize)
# Useful for slow-starting applications
# HEALTH_CHECK_START_PERIOD=60


# ============================================================================
# PRODUCTION-SPECIFIC CONFIGURATION
# ============================================================================
# Uncomment and configure these for production deployment
# These settings enhance security and performance in production environments

# SSL/TLS Configuration (for HTTPS)
# Required for production to enable secure HTTPS connections
# 
# How to get SSL certificates:
# 1. Free option: Use Let's Encrypt (https://letsencrypt.org/)
#    - Automated with Certbot: https://certbot.eff.org/
# 2. Paid option: Purchase from SSL certificate providers
# 3. Cloud option: Use cloud provider's certificate manager
#    - AWS: ACM (AWS Certificate Manager)
#    - GCP: Google-managed SSL certificates
#    - Azure: App Service Certificates
# 
# After obtaining certificates, place them in nginx/ssl/ directory
# SSL_CERT_PATH=/etc/nginx/ssl/certificate.crt
# SSL_KEY_PATH=/etc/nginx/ssl/private.key

# Domain configuration
# Your production domain name (without http:// or https://)
# Used for SSL certificate validation and CORS configuration
# Example: specweave.com or app.specweave.com
# DOMAIN=yourdomain.com

# Rate limiting (requests per minute)
# Protects your API from abuse and DDoS attacks
# 
# RATE_LIMIT_WINDOW_MS: Time window in milliseconds
#   - 60000 = 1 minute
#   - 300000 = 5 minutes
# RATE_LIMIT_MAX_REQUESTS: Maximum requests per window per IP
#   - 100 = Generous limit for normal users
#   - 50 = Stricter limit for high-security applications
#   - 1000 = Very permissive (use with caution)
# 
# Example: 100 requests per minute = 1.67 requests per second
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX_REQUESTS=100

# Session configuration (if using sessions)
# SESSION_SECRET: Secret key for signing session cookies
#   Generate with: openssl rand -base64 32
# SESSION_MAX_AGE: Session lifetime in milliseconds
#   - 86400000 = 24 hours
#   - 604800000 = 7 days
# SESSION_SECRET=change-this-to-a-strong-random-secret-in-production
# SESSION_MAX_AGE=86400000

# CORS configuration (advanced)
# By default, CLIENT_URL is used for CORS
# Uncomment to override with more specific settings
# CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com
# CORS_CREDENTIALS=true
# CORS_MAX_AGE=86400


# ============================================================================
# DEVELOPMENT-SPECIFIC CONFIGURATION
# ============================================================================
# These are only used in development mode (NODE_ENV=development)
# Automatically enabled when using docker-compose.dev.yml

# Enable hot reload for frontend (Vite dev server)
# true: Changes to frontend code automatically refresh the browser
# false: Manual refresh required after code changes
# Note: Automatically enabled in docker-compose.dev.yml
# DEV_HOT_RELOAD=true

# Enable auto-restart for backend (Nodemon)
# true: Backend automatically restarts when code changes
# false: Manual restart required after code changes
# Note: Automatically enabled in docker-compose.dev.yml
# DEV_AUTO_RESTART=true

# Enable source maps
# true: Generate source maps for easier debugging (larger bundle size)
# false: No source maps (smaller bundle, harder to debug)
# Recommended: true for development, false for production
# DEV_SOURCE_MAPS=true

# Enable React DevTools
# true: Enable React Developer Tools browser extension support
# false: Disable React DevTools (slightly better performance)
# DEV_REACT_DEVTOOLS=true

# Enable verbose error messages
# true: Show full error stack traces and details
# false: Show minimal error messages
# DEV_VERBOSE_ERRORS=true


# ============================================================================
# INSTRUCTIONS
# ============================================================================
#
# QUICK START:
# ------------
# 1. Copy this file to .env:
#    cp .env.example .env
#
# 2. Fill in all REQUIRED variables (search for "REQUIRED" above)
#    - VITE_SUPABASE_URL
#    - VITE_SUPABASE_ANON_KEY
#    - VITE_API_BASE_URL
#    - SUPABASE_URL
#    - SUPABASE_ANON_KEY
#    - SUPABASE_SERVICE_ROLE_KEY
#    - GROQ_API_KEY
#
# 3. Start the application:
#    Development: docker-compose -f docker-compose.yml -f docker-compose.dev.yml up
#    Production:  docker-compose -f docker-compose.yml -f docker-compose.prod.yml up -d
#
# DETAILED SETUP GUIDES:
# ----------------------
#
# 1. SUPABASE SETUP:
#    a. Create a project at https://supabase.com
#    b. Go to Settings > API
#    c. Copy your Project URL to SUPABASE_URL and VITE_SUPABASE_URL
#    d. Copy your anon/public key to SUPABASE_ANON_KEY and VITE_SUPABASE_ANON_KEY
#    e. Copy your service_role key to SUPABASE_SERVICE_ROLE_KEY
#    
#    SECURITY WARNING:
#    - anon key: Safe to expose in frontend (limited permissions)
#    - service_role key: NEVER expose in frontend! (admin permissions)
#
# 2. GROQ AI SETUP:
#    a. Sign up at https://console.groq.com
#    b. Navigate to API Keys section
#    c. Click "Create API Key"
#    d. Copy the key to GROQ_API_KEY
#    
#    SECURITY WARNING: Keep this key secret! Never commit to version control!
#
# 3. JIRA INTEGRATION (Optional):
#    a. Generate a strong encryption key:
#       Linux/Mac: openssl rand -base64 32
#       Windows: [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Minimum 0 -Maximum 256 }))
#    b. Replace JIRA_ENCRYPTION_KEY with the generated key
#    
#    SECURITY WARNING: If you lose this key, all JIRA credentials become unrecoverable!
#
# 4. DEVELOPMENT CONFIGURATION:
#    - Keep NODE_ENV=development
#    - Use localhost URLs:
#      * VITE_API_BASE_URL=http://localhost:5003
#      * CLIENT_URL=http://localhost:3000
#    - Enable verbose logging: LOG_LEVEL=DEBUG (if needed)
#    - Use docker-compose.dev.yml for hot-reload
#
# 5. PRODUCTION CONFIGURATION:
#    - Change NODE_ENV=production
#    - Generate strong JIRA_ENCRYPTION_KEY (see step 3)
#    - Configure SSL certificates (see PRODUCTION-SPECIFIC CONFIGURATION section)
#    - Set appropriate CORS origins in CLIENT_URL
#    - Enable CLEAN_LOGS=true to reduce log noise
#    - Use docker-compose.prod.yml with Nginx reverse proxy
#    - Set VITE_API_BASE_URL=/api (uses reverse proxy)
#    - Configure your domain in DOMAIN variable
#    - Enable rate limiting (uncomment RATE_LIMIT_* variables)
#
# 6. SECURITY CHECKLIST FOR PRODUCTION:
#    ✓ Change all default passwords and keys
#    ✓ Use strong JIRA_ENCRYPTION_KEY (32+ characters)
#    ✓ Never commit .env file to version control
#    ✓ Use HTTPS with valid SSL certificates
#    ✓ Enable rate limiting
#    ✓ Set appropriate CORS origins (don't use *)
#    ✓ Use secrets management in cloud (AWS Secrets Manager, etc.)
#    ✓ Regularly rotate API keys and passwords
#    ✓ Monitor logs for suspicious activity
#    ✓ Keep Docker images updated
#
# 7. TROUBLESHOOTING:
#    - If containers fail to start, check logs: docker-compose logs
#    - If API calls fail, verify VITE_API_BASE_URL matches your setup
#    - If CORS errors occur, check CLIENT_URL includes your frontend URL
#    - If Python services fail, rebuild backend: docker-compose build backend
#    - For detailed troubleshooting, see README-DOCKER.md
#
# 8. USEFUL COMMANDS:
#    - View logs: docker-compose logs -f
#    - Restart services: docker-compose restart
#    - Rebuild images: docker-compose build
#    - Stop services: docker-compose down
#    - Health check: ./scripts/health-check.sh
#    - Backup volumes: ./scripts/backup-volumes.sh <volume-name> ./backups
#
# 9. GETTING HELP:
#    - Read README-DOCKER.md for comprehensive documentation
#    - Check troubleshooting section in README-DOCKER.md
#    - Run health check script: ./scripts/health-check.sh
#    - Check container logs: docker-compose logs [service-name]
#    - Open an issue on the repository
#
# ============================================================================
