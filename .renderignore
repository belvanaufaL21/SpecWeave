# Render Ignore File
# Files and directories that should not be uploaded to Render

# Development files
.kiro/
skrip-utilitas/
*.bat

# Documentation (internal)
*SUMMARY.md
*CHECKPOINT*.md
*ISSUE-FIX*.md
*MIGRATION-*.md
*TASK-*.md
*BUG-FIX*.md
CARA-MENGHILANGKAN-LOG*.md
CONSOLE-CLEANUP-SUMMARY.md
QUICK-LOGGING-FIX.md
remove-verbose-logs*.ps1
clear-cache-and-restart.ps1

# VPS-specific files (not needed for Render)
docker-compose.yml
docker-compose.dev.yml
docker-compose.prod.yml
nginx/default.conf
nginx/nginx.conf
nginx/ssl/
scripts/setup-letsencrypt.sh
scripts/renew-letsencrypt.sh
scripts/backup-volumes.sh
scripts/restore-volumes.sh

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Environment files (set via Render dashboard)
.env
.env.local
.env.*.local

# Dependencies (will be installed during build)
node_modules/
*/node_modules/

# Build outputs (will be generated during build)
dist/
build/
*/dist/
*/build/

# Python
__pycache__/
*.pyc
meteor_env/

# Database
*.db
*.sqlite
*.sqlite3

# SSL Certificates
*.pem
*.key
*.crt
keys/
